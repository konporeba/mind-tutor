---
import Layout from "@/layouts/Layout.astro";
import NewSessionForm from "@/components/session/NewSessionForm";
---

<Layout title="New session">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <a href="/dashboard" class="text-sm text-blue-100/60 transition-colors hover:text-white">← Dashboard</a>
      <h1
        class="mt-4 mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent"
      >
        New session
      </h1>
      <p class="mb-6 text-sm text-blue-100/70">
        Upload one study file. MindTutor will generate a short, guided session grounded in it.
      </p>
      <NewSessionForm client:load />
    </div>
  </div>
</Layout>

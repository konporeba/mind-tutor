---
import Layout from "@/layouts/Layout.astro";
import SessionRunner from "@/components/session/SessionRunner";
import type {
  TheoryStepView,
  ExerciseView,
  McqExerciseView,
  FillBlankExerciseView,
  MatchingExerciseView,
} from "@/components/session/SessionRunner";
import type { ChatTurn } from "@/components/session/AskTutorPanel";
import { createClient } from "@/lib/supabase";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase || !id) {
  return Astro.redirect("/dashboard");
}

// RLS scopes this to the owner; a non-owned or missing id yields an error.
const { data: session, error } = await supabase
  .from("sessions")
  .select("id, title, status, score")
  .eq("id", id)
  .single();

if (error) {
  return Astro.redirect("/dashboard");
}

const { data: contentRows } = await supabase
  .from("generated_content")
  .select("position, body")
  .eq("session_id", id)
  .eq("kind", "theory")
  .order("position");

const { data: exerciseRows } = await supabase
  .from("exercises")
  .select("id, kind, position, prompt, options, correct_answer, learner_answer, is_correct, feedback, answered_at")
  .eq("session_id", id)
  .order("position");

// Ask-the-tutor transcript (S-05): RLS-scoped to the owner, ordered for replay.
const { data: turnRows } = await supabase
  .from("conversation_messages")
  .select("role, content")
  .eq("session_id", id)
  .order("position");

const initialTurns: ChatTurn[] = (turnRows ?? []).map((row) => ({
  role: row.role as ChatTurn["role"],
  content: row.content,
}));

const theory: TheoryStepView[] = (contentRows ?? []).map((row) => {
  const body = row.body as { heading?: string; body?: string; citation?: string };
  return {
    position: row.position,
    heading: body.heading ?? "",
    body: body.body ?? "",
    citation: body.citation ?? "",
  };
});

const exercises: ExerciseView[] = (exerciseRows ?? []).map((row) => {
  const answered = row.answered_at !== null;
  const base = {
    id: row.id,
    position: row.position,
    prompt: row.prompt,
    is_correct: row.is_correct,
    feedback: row.feedback,
  };

  // Only expose the correct answer / solution mapping for already-answered items;
  // pre-answer, options carry just the displayable data (never the truth).
  if (row.kind === "matching") {
    const opts = (row.options ?? {}) as { left?: unknown; right?: unknown };
    const matching: MatchingExerciseView = {
      ...base,
      kind: "matching",
      left: Array.isArray(opts.left) ? (opts.left as string[]) : [],
      right: Array.isArray(opts.right) ? (opts.right as string[]) : [],
      learner_answer:
        answered && row.learner_answer && typeof row.learner_answer === "object"
          ? (row.learner_answer as Record<string, string>)
          : null,
      correct_answer: answered ? (row.correct_answer as MatchingExerciseView["correct_answer"]) : null,
    };
    return matching;
  }

  if (row.kind === "fill_blank") {
    const fill: FillBlankExerciseView = {
      ...base,
      kind: "fill_blank",
      learner_answer: answered && typeof row.learner_answer === "string" ? row.learner_answer : null,
      correct_answer: answered ? (row.correct_answer as FillBlankExerciseView["correct_answer"]) : null,
    };
    return fill;
  }

  const mcq: McqExerciseView = {
    ...base,
    kind: "mcq",
    options: Array.isArray(row.options) ? (row.options as string[]) : [],
    learner_answer: typeof row.learner_answer === "string" ? row.learner_answer : null,
    correct_answer: answered && typeof row.correct_answer === "string" ? row.correct_answer : null,
  };
  return mcq;
});
---

<Layout title={session.title ?? "Study session"}>
  <div class="bg-cosmic min-h-screen">
    <SessionRunner
      client:load
      sessionId={session.id}
      title={session.title}
      initialStatus={session.status}
      initialScore={session.score}
      theory={theory}
      exercises={exercises}
      initialTurns={initialTurns}
    />
  </div>
</Layout>

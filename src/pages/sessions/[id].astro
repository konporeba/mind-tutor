---
import Layout from "@/layouts/Layout.astro";
import SessionRunner from "@/components/session/SessionRunner";
import type {
  TheoryStepView,
  ExerciseView,
  McqExerciseView,
  FillBlankExerciseView,
  MatchingExerciseView,
} from "@/components/session/SessionRunner";
import type { ChatTurn } from "@/components/session/AskTutorPanel";
import ConversationLog from "@/components/session/ConversationLog.astro";
import { createClient } from "@/lib/supabase";
import { loadSessionMaterials } from "@/lib/services/history/materials";
import { loadConversation } from "@/lib/services/history/conversation";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase || !id) {
  return Astro.redirect("/dashboard");
}

// RLS scopes this to the owner; a non-owned or missing id yields an error.
const { data: session, error } = await supabase
  .from("sessions")
  .select("id, title, status, score")
  .eq("id", id)
  .single();

if (error) {
  return Astro.redirect("/dashboard");
}

const { data: contentRows } = await supabase
  .from("generated_content")
  .select("position, body")
  .eq("session_id", id)
  .eq("kind", "theory")
  .order("position");

const { data: exerciseRows } = await supabase
  .from("exercises")
  .select("id, kind, position, prompt, options, correct_answer, learner_answer, is_correct, feedback, answered_at")
  .eq("session_id", id)
  .order("position");

// Ask-the-tutor transcript (S-05/S-06): RLS-scoped, ordered for replay. Seeds the
// live panel on an in-progress session and the read-only ConversationLog on a
// completed one.
const turns = await loadConversation(supabase, id);
const initialTurns: ChatTurn[] = turns.map((t) => ({ role: t.role as ChatTurn["role"], content: t.content }));

// Uploaded file(s) with a short-lived signed download URL (S-06). A missing
// storage_path or a signing failure yields a filename-only entry (no throw).
const materials = await loadSessionMaterials(supabase, id);
const materialViews = await Promise.all(
  materials.map(async (m) => {
    let downloadUrl: string | null = null;
    if (m.storage_path) {
      const { data: signed } = await supabase.storage.from("materials").createSignedUrl(m.storage_path, 60);
      downloadUrl = signed?.signedUrl ?? null;
    }
    return { filename: m.filename, sizeBytes: m.size_bytes, downloadUrl };
  }),
);

function formatBytes(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

const theory: TheoryStepView[] = (contentRows ?? []).map((row) => {
  const body = row.body as { heading?: string; body?: string; citation?: string };
  return {
    position: row.position,
    heading: body.heading ?? "",
    body: body.body ?? "",
    citation: body.citation ?? "",
  };
});

const exercises: ExerciseView[] = (exerciseRows ?? []).map((row) => {
  const answered = row.answered_at !== null;
  const base = {
    id: row.id,
    position: row.position,
    prompt: row.prompt,
    is_correct: row.is_correct,
    feedback: row.feedback,
  };

  // Only expose the correct answer / solution mapping for already-answered items;
  // pre-answer, options carry just the displayable data (never the truth).
  if (row.kind === "matching") {
    const opts = (row.options ?? {}) as { left?: unknown; right?: unknown };
    const matching: MatchingExerciseView = {
      ...base,
      kind: "matching",
      left: Array.isArray(opts.left) ? (opts.left as string[]) : [],
      right: Array.isArray(opts.right) ? (opts.right as string[]) : [],
      learner_answer:
        answered && row.learner_answer && typeof row.learner_answer === "object"
          ? (row.learner_answer as Record<string, string>)
          : null,
      correct_answer: answered ? (row.correct_answer as MatchingExerciseView["correct_answer"]) : null,
    };
    return matching;
  }

  if (row.kind === "fill_blank") {
    const fill: FillBlankExerciseView = {
      ...base,
      kind: "fill_blank",
      learner_answer: answered && typeof row.learner_answer === "string" ? row.learner_answer : null,
      correct_answer: answered ? (row.correct_answer as FillBlankExerciseView["correct_answer"]) : null,
    };
    return fill;
  }

  const mcq: McqExerciseView = {
    ...base,
    kind: "mcq",
    options: Array.isArray(row.options) ? (row.options as string[]) : [],
    learner_answer: typeof row.learner_answer === "string" ? row.learner_answer : null,
    correct_answer: answered && typeof row.correct_answer === "string" ? row.correct_answer : null,
  };
  return mcq;
});
---

<Layout title={session.title ?? "Study session"}>
  <div class="bg-cosmic min-h-screen">
    <SessionRunner
      client:load
      sessionId={session.id}
      title={session.title}
      initialStatus={session.status}
      initialScore={session.score}
      theory={theory}
      exercises={exercises}
      initialTurns={initialTurns}
    />

    <div class="mx-auto max-w-5xl space-y-6 p-4 pt-0 text-white">
      {
        materialViews.length > 0 && (
          <section class="space-y-3 rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
            <h2 class="text-sm font-semibold tracking-wide text-blue-100/60 uppercase">Materials</h2>
            <ul class="space-y-2">
              {materialViews.map((m) => (
                <li class="flex items-center justify-between gap-4 rounded-xl border border-white/10 bg-white/5 px-4 py-3">
                  <span class="min-w-0">
                    <span class="block truncate text-white">{m.filename}</span>
                    <span class="text-xs text-blue-100/60">{formatBytes(m.sizeBytes)}</span>
                  </span>
                  {m.downloadUrl ? (
                    <a
                      href={m.downloadUrl}
                      download
                      class="shrink-0 text-sm text-blue-200 transition-colors hover:text-white"
                    >
                      Download
                    </a>
                  ) : (
                    <span class="shrink-0 text-xs text-blue-100/40">Unavailable</span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {session.status === "completed" && <ConversationLog turns={turns} />}
    </div>
  </div>
</Layout>

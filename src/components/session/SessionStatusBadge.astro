---
// Small, accessible status badge for a session (S-06). Used by the dashboard
// history list (and reusable on the detail header). The status word is readable
// text, never colour-only.
interface Props {
  status: string;
}

const { status: sessionStatus } = Astro.props;

const STYLES: Record<string, string> = {
  completed: "border-green-400/40 bg-green-500/20 text-green-100",
  active: "border-blue-400/40 bg-blue-500/20 text-blue-100",
  abandoned: "border-white/20 bg-white/10 text-blue-100/70",
};

const LABELS: Record<string, string> = {
  completed: "Completed",
  active: "In progress",
  abandoned: "Abandoned",
};

const className = STYLES[sessionStatus] ?? STYLES.abandoned;
const label = LABELS[sessionStatus] ?? sessionStatus;
---

<span class:list={["inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium", className]}>
  {label}
</span>

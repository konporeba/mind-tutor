---
// Read-only ask-the-tutor transcript for a completed session (S-06). Renders the
// persisted turns as bubbles with no input affordance — revisiting history must
// not mutate a finished session (S-05's live panel owns active sessions). Static
// markup only; no React island.
import type { ConversationTurn } from "@/lib/services/history/conversation";

interface Props {
  turns: ConversationTurn[];
}

const { turns } = Astro.props;
---

<section class="space-y-4 rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
  <h2 class="text-sm font-semibold tracking-wide text-blue-100/60 uppercase">Conversation</h2>

  {
    turns.length === 0 ? (
      <p class="text-sm text-blue-100/60">No questions were asked in this session.</p>
    ) : (
      <ol class="space-y-3">
        {turns.map((turn) => (
          <li class:list={["flex", turn.role === "user" ? "justify-end" : "justify-start"]}>
            <div
              class:list={[
                "max-w-[80%] rounded-2xl px-4 py-2.5 text-sm whitespace-pre-wrap",
                turn.role === "user"
                  ? "bg-gradient-to-r from-blue-500/80 to-purple-500/80 text-white"
                  : "border border-white/10 bg-white/5 text-blue-100/90",
              ]}
            >
              {turn.content}
            </div>
          </li>
        ))}
      </ol>
    )
  }
</section>
